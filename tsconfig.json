{
  "include": ["app"],

  "compilerOptions": {
    "strict": true,
    "types": ["node", "vite/client"],
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "removeComments": true,
    "baseUrl": "./",
    "paths": { "~/*": ["app/*"] }
  }
}
